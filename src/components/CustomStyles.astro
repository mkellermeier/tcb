---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Schwarzwald Forest Green – Light Mode */
    --aw-color-primary: rgb(22 101 52);
    --aw-color-secondary: rgb(14 70 36);
    --aw-color-accent: rgb(34 160 80);

    --aw-color-text-heading: rgb(18 28 22);
    --aw-color-text-default: rgb(18 28 22);
    --aw-color-text-muted: rgb(18 28 22 / 58%);
    --aw-color-text-page: rgb(18 28 22);

    /* Backgrounds */
    --aw-color-bg-page: rgb(243 248 244);       /* Seitenhintergrund */
    --aw-color-bg-page-light: rgb(255 255 255); /* Elevated Cards (.bg-light) */
    --aw-color-bg-page-dark: rgb(224 237 226);  /* Inset Areas (.bg-dark) */

    --aw-color-bg-header-scroll: rgba(243, 248, 244, 0.92);

    ::selection {
      background-color: rgb(22 101 52 / 18%);
      color: rgb(18 28 22);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Forest Dusk – Dark Mode */
    --aw-color-primary: rgb(46 168 104);
    --aw-color-secondary: rgb(25 100 58);
    --aw-color-accent: rgb(74 222 128);

    --aw-color-text-heading: rgb(218 232 222);
    --aw-color-text-default: rgb(218 232 222);
    --aw-color-text-muted: rgb(218 232 222 / 68%);
    --aw-color-text-page: rgb(218 232 222);

    --aw-color-bg-page: rgb(13 21 16);        /* Seitenhintergrund */
    --aw-color-bg-page-light: rgb(19 31 23);  /* Elevated Cards */
    --aw-color-bg-page-dark: rgb(8 13 10);    /* Inset Areas */

    --aw-color-bg-header-scroll: rgba(13, 21, 16, 0.92);

    ::selection {
      background-color: rgb(46 168 104 / 35%);
      color: white;
    }
  }
</style>
