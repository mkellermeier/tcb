---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Schwarzwald Tannengrün */
    --aw-color-primary: rgb(13 64 36); /* tiefes Waldgrün */
    --aw-color-secondary: rgb(8 42 24); /* dunkler Schatten */
    --aw-color-accent: rgb(34 139 94); /* frisches Nadelgrün */

    /* Light Mode (wird kaum genutzt bei dark:only, aber sauber halten) */
    --aw-color-text-heading: rgb(20 20 20);
    --aw-color-text-default: rgb(28 28 28);
    --aw-color-text-muted: rgb(28 28 28 / 66%);
    --aw-color-bg-page: rgb(245 247 246);

    /* Hintergrund */
    --aw-color-bg-page-dark: rgb(7 12 10);

    ::selection {
      background-color: rgb(34 139 94 / 30%);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(34 139 94); /* Buttons / Links */
    --aw-color-secondary: rgb(13 64 36); /* Hover / Depth */
    --aw-color-accent: rgb(74 222 128); /* subtile Highlights */

    --aw-color-text-heading: rgb(238 242 240);
    --aw-color-text-default: rgb(210 218 214);
    --aw-color-text-muted: rgb(210 218 214 / 60%);

    --aw-color-bg-page: rgb(7 12 10); /* fast schwarz mit Grünanteil */

    ::selection {
      background-color: rgb(34 139 94 / 40%);
      color: white;
    }
  }
</style>
