---
type ImageItem = {
  src: string;
  alt?: string;
  caption?: string;
};

const { images = [] } = Astro.props as { images?: ImageItem[] };
---

{images.length > 0 && (
  <section class="mt-10">
    <h2 class="text-xl font-semibold mb-4">Bilder</h2>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {images.map((img) => (
        <figure class="overflow-hidden rounded-2xl border border-gray-500/20 bg-light">
          <a href={img.src} target="_blank" rel="noopener">
            <img
              src={img.src}
              alt={img.alt ?? ''}
              loading="lazy"
              class="h-40 md:h-48 w-full object-cover hover:opacity-90 transition"
            />
          </a>
          {img.caption && <figcaption class="p-3 text-sm text-muted">{img.caption}</figcaption>}
        </figure>
      ))}
    </div>

    <p class="text-sm text-muted mt-3">Tipp: Klick öffnet das Bild in voller Größe.</p>
  </section>
)}