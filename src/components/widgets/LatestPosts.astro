---
import { getCollection } from "astro:content";
const { limit = 3 } = Astro.props;

const items = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, limit);

const fmt = (d: Date) =>
  new Intl.DateTimeFormat("de-DE", { day: "2-digit", month: "long", year: "numeric" }).format(d);
---

<section class="py-16 md:py-24" id="beitraege">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Neueste Beiträge</h2>
      <p class="mt-3 text-base text-gray-600 dark:text-gray-300">
        Rückblicke, Vereinsleben und alles, was bei uns passiert ist.
      </p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((e) => (
        <article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-md dark:border-gray-800 dark:bg-gray-900">
          {e.data.coverImage && (
            <a href={`/beitraege/${e.slug}/`} class="block overflow-hidden rounded-xl">
              <img src={e.data.coverImage} alt={e.data.title} class="h-44 w-full object-cover" loading="lazy" />
            </a>
          )}

          <p class="mt-4 text-sm text-gray-500 dark:text-gray-400">
            {fmt(e.data.date)}
            {e.data.gallery?.length ? <span> • {e.data.gallery.length} Fotos</span> : null}
          </p>

          <h3 class="mt-2 text-lg font-semibold">
            <a href={`/beitraege/${e.slug}/`} class="hover:underline">{e.data.title}</a>
          </h3>

          {e.data.excerpt && <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">{e.data.excerpt}</p>}
        </article>
      ))}
    </div>

    <div class="mt-10">
      <a href="/beitraege/" class="inline-flex items-center rounded-xl border border-gray-300 px-4 py-2 text-sm font-medium hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-800">
        Alle Beiträge
        <span class="ml-2">→</span>
      </a>
    </div>
  </div>
</section>