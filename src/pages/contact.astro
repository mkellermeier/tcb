---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Kontakt',
  description: 'Kontakt zum TC Bühlertal – wir freuen uns auf deine Nachricht.',
};

const email = 'tcbuehlertal@web.de';
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Kontakt"
    title="Schreib uns!"
    subtitle="Fragen zur Mitgliedschaft, Platzbuchung oder Vereinsaktivitäten? Wir melden uns so schnell wie möglich zurück."
  />

  <section class="max-w-5xl mx-auto px-4 pb-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Contact info -->
      <div class="space-y-4">
        <div class="rounded-2xl border border-gray-500/20 bg-light p-6">
          <h2 class="text-lg font-semibold">Kontaktdaten</h2>
          <ul class="mt-4 space-y-3 text-sm text-muted">
            <li class="flex items-start gap-3">
              <span class="mt-0.5 text-page">✉</span>
              <a class="hover:underline" href={`mailto:${email}`}>{email}</a>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-0.5 text-page">📍</span>
              <span>Tennisanlage TC Bühlertal<br />Bühlertal, Baden-Württemberg</span>
            </li>
          </ul>
        </div>

        <div class="rounded-2xl border border-gray-500/20 bg-light p-6">
          <h2 class="text-lg font-semibold">Schnellzugriff</h2>
          <div class="mt-4 flex flex-col gap-2">
            <a class="btn btn-secondary" href="/membership">Mitglied werden</a>
            <a class="btn btn-secondary" href="/guest-players">Platz als Gastspieler buchen</a>
            <a class="btn btn-secondary" href="/board">Vorstand kontaktieren</a>
          </div>
        </div>
      </div>

      <!-- mailto CTA -->
      <div class="rounded-2xl border border-gray-500/20 bg-dark p-6 flex flex-col justify-between">
        <div>
          <h2 class="text-lg font-semibold">Nachricht senden</h2>
          <p class="text-muted mt-2 text-sm leading-relaxed">
            Klicke auf den Button, um direkt eine E-Mail zu verfassen. Gib dabei kurz an, worum es geht –
            wir antworten so bald wie möglich.
          </p>
        </div>
        <div class="mt-6">
          <a
            class="btn btn-primary"
            href={`mailto:${email}?subject=Anfrage%20TC%20B%C3%BChlertal`}
          >
            E-Mail schreiben
          </a>
        </div>
      </div>
    </div>
  </section>

  <Features2
    title="Womit können wir helfen?"
    items={[
      {
        title: 'Mitgliedschaft',
        description: 'Fragen zu Beiträgen, Aufnahme oder Kündigungen beantworten wir gerne.',
        icon: 'tabler:id-badge-2',
      },
      {
        title: 'Platzbuchung',
        description: 'Für Gastspieler und Anfragen zur Platzverfügbarkeit einfach mailen.',
        icon: 'tabler:calendar-check',
      },
      {
        title: 'Veranstaltungen',
        description: 'Informationen zu Turnieren, Events und Vereinsaktivitäten.',
        icon: 'tabler:calendar-event',
      },
      {
        title: 'E-Mail',
        description: email,
        icon: 'tabler:mail',
      },
      {
        title: 'Adresse',
        description: 'Bühlertal, Baden-Württemberg',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Anlage',
        description: '6 Sandplätze, Clubhaus mit Terrasse.',
        icon: 'tabler:building',
      },
    ]}
  />
</Layout>
