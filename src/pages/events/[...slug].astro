---
import { getCollection } from "astro:content";
import { Markdown } from "astro/components";

export async function getStaticPaths() {
  const events = await getCollection("events");
  return events
    .filter((e) => !e.data.draft)
    .map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const events = await getCollection("events");
const entry = events.find((e) => e.slug === slug);

if (!entry) throw new Error("Event nicht gefunden");
const { Content, data } = entry;
---

<html lang="de">
  <head>
    <title>{data.title}</title>
  </head>
  <body class="bg-page text-page">
    <main class="max-w-3xl mx-auto px-4 py-10">
      <a href="/events/" class="text-sm text-muted hover:underline">← Zurück zu Events</a>
      <h1 class="text-3xl font-semibold mt-3">{data.title}</h1>

      <div class="mt-3 text-muted">
        <div>{data.start.toLocaleDateString("de-DE")}</div>
        {data.location && <div>{data.location}</div>}
        {data.signupUrl && (
          <div class="mt-2">
            <a class="btn btn-primary" href={data.signupUrl} target="_blank" rel="noopener">
              Anmelden / Info
            </a>
          </div>
        )}
      </div>

      <article class="prose dark:prose-invert mt-8">
        <Content />
      </article>
    </main>
  </body>
</html>