---
import Layout from '~/layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';

export async function getStaticPaths() {
  const entries = await getCollection('events', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const d = entry.data;

const metadata = {
  title: d.title,
  description: d.description ?? `${d.title} – TC Bühlertal`,
};

const fmtLong = (date: Date) =>
  date.toLocaleDateString('de-DE', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' });

const fmtShort = (date: Date) =>
  date.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' });

const isMultiDay =
  d.endDate && d.endDate.toDateString() !== d.startDate.toDateString();
---

<Layout metadata={metadata}>
  <section class="max-w-3xl mx-auto px-4 py-12 space-y-6">
    <div>
      <a class="btn btn-secondary" href="/events">← Zurück zur Übersicht</a>
    </div>

    <div class="rounded-2xl border border-gray-500/20 bg-light p-6 space-y-6">
      <div>
        <h1 class="text-2xl font-bold text-page leading-snug">{d.title}</h1>
        {d.description && (
          <p class="text-muted mt-2 leading-relaxed">{d.description}</p>
        )}
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm border-t border-gray-500/20 pt-5">
        <div class="flex items-start gap-3">
          <Icon name="tabler:calendar" class="w-5 h-5 text-primary mt-0.5 shrink-0" />
          <div>
            <div class="text-muted">Datum</div>
            <div class="text-page font-medium">
              {isMultiDay
                ? `${fmtShort(d.startDate)} – ${fmtShort(d.endDate!)}`
                : fmtLong(d.startDate)}
            </div>
          </div>
        </div>

        {d.time && (
          <div class="flex items-start gap-3">
            <Icon name="tabler:clock" class="w-5 h-5 text-primary mt-0.5 shrink-0" />
            <div>
              <div class="text-muted">Uhrzeit</div>
              <div class="text-page font-medium">{d.time} Uhr</div>
            </div>
          </div>
        )}

        {d.location && (
          <div class="flex items-start gap-3">
            <Icon name="tabler:map-pin" class="w-5 h-5 text-primary mt-0.5 shrink-0" />
            <div>
              <div class="text-muted">Ort</div>
              <div class="text-page font-medium">{d.location}</div>
            </div>
          </div>
        )}
      </div>
    </div>

    {entry.body?.trim() && (
      <div class="rounded-2xl border border-gray-500/20 bg-light p-6">
        <article class="prose dark:prose-invert max-w-none">
          <Content />
        </article>
      </div>
    )}

    <div>
      <a class="btn btn-secondary" href="/contact">Fragen? Kontakt aufnehmen</a>
    </div>
  </section>
</Layout>
