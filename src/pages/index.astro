---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { getCollection } from 'astro:content';

const metadata = {
  title: 'TC Bühlertal',
  ignoreTitleTemplate: true,
  description: 'Spielbetrieb, Termine, Platzbuchung und Vereinsinfos.',
};

const now = new Date();

// ---------- helpers ----------
function formatShortDate(d: Date) {
  return d.toLocaleDateString('de-DE', { weekday: 'short', day: '2-digit', month: '2-digit' });
}

function daysBetween(a: Date, b: Date) {
  // normalize to midnight to avoid timezone edge cases
  const da = new Date(a.getFullYear(), a.getMonth(), a.getDate()).getTime();
  const db = new Date(b.getFullYear(), b.getMonth(), b.getDate()).getTime();
  return Math.round((db - da) / (1000 * 60 * 60 * 24));
}

function relativeLabel(d: Date) {
  const diff = daysBetween(now, d);
  if (diff === 0) return 'Heute';
  if (diff === 1) return 'Morgen';
  if (diff > 1 && diff <= 7) return `in ${diff} Tagen`;
  return '';
}

function homeAwayLabel(v: 'home' | 'away') {
  return v === 'home' ? 'Heim' : 'Auswärts';
}

// ---------- matches ----------
const matchesAll = (await getCollection('matches', ({ data }) => !data.draft)).sort(
  (a, b) => +a.data.matchDate - +b.data.matchDate
);

const upcomingMatches = matchesAll.filter((m) => m.data.matchDate >= now).slice(0, 5);

// ---------- events (optional if you have it) ----------
const eventsAll = (await getCollection('events', ({ data }) => !data.draft)).sort(
  (a, b) => +a.data.startDate - +b.data.startDate
);

const upcomingEvents = eventsAll.filter((e) => e.data.startDate >= now).slice(0, 5);

// ---------- latest posts ----------
const postsAll = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const latestPosts = postsAll.slice(0, 3);
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero
    actions={[
      { variant: 'primary', text: 'Spiele & Ergebnisse', href: '/matches', icon: 'tabler:trophy' },
      { text: 'Termine', href: '/events', icon: 'tabler:calendar-event' },
    ]}
    image={{ src: '~/assets/images/hero-blackforest.png', alt: 'Tennis im Schwarzwald' }}
  >
    <Fragment slot="title">
      Tennis im <span class="text-accent dark:text-white">Schwarzwald</span>
    </Fragment>

    <Fragment slot="subtitle"> Spielbetrieb, Termine und Vereinsinfos – alles an einem Ort. </Fragment>
  </Hero>

  <!-- Aktuelles / Quick Info -->
  <section class="max-w-5xl mx-auto px-4 py-10 space-y-10">
    <!-- Welcome -->
    <div class="rounded-2xl border border-gray-500/20 bg-light p-6">
      <h2 class="text-2xl font-semibold text-page">Hallo Tennisfreunde,</h2>
      <p class="text-muted leading-relaxed mt-3">
        schön, dass ihr da seid und herzlich Willkommen beim <span class="font-semibold text-page">TC Bühlertal</span>!
      </p>

      <p class="text-muted leading-relaxed mt-4">
        Unser Club wurde <span class="font-semibold text-page">1965</span> gegründet und bietet seither alles, was das Tennisherz
        höher schlagen lässt.
      </p>

      <p class="text-muted leading-relaxed mt-4">
        Umgeben von Wäldern laden <span class="font-semibold text-page">sechs Sandplätze</span> und ein Clubhaus mit großer
        Terrasse zum Verweilen ein. Events, kulinarische Abende und gemeinsame Ausflüge machen das Vereinsleben komplett.
      </p>

      <div class="mt-6 flex flex-wrap gap-2">
        <span class="rounded-full border border-gray-500/20 bg-dark px-3 py-1 text-xs text-muted">Gegründet 1965</span>
        <span class="rounded-full border border-gray-500/20 bg-dark px-3 py-1 text-xs text-muted">6 Sandplätze</span>
        <span class="rounded-full border border-gray-500/20 bg-dark px-3 py-1 text-xs text-muted"
          >Clubhaus & Terrasse</span
        >
      </div>

      <div class="mt-6 flex flex-col sm:flex-row gap-3">
        <a class="btn btn-secondary" href="/facility">Anlage entdecken</a>
        <a class="btn btn-secondary" href="/membership">Mitglied werden</a>
        <a class="btn btn-secondary" href="/contact">Kontakt</a>
      </div>
    </div>

    <!-- Quick cards -->
    <div>
      <h2 class="text-2xl font-semibold mb-4">Aktuelles</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Matches Card -->
        <div class="rounded-2xl border border-gray-500/20 bg-light p-5">
          <div class="flex items-center justify-between gap-3">
            <h3 class="font-semibold text-page">Nächste Spiele</h3>
            <a class="text-sm text-muted hover:underline" href="/matches">Alle Spiele →</a>
          </div>

          {
            upcomingMatches.length === 0 ? (
              <div class="mt-3">
                <p class="text-muted text-sm leading-relaxed">Aktuell sind keine Spiele veröffentlicht.</p>
                <div class="mt-4">
                  <a class="btn btn-secondary" href="/contact">
                    Kontakt aufnehmen
                  </a>
                </div>
              </div>
            ) : (
              <ul class="mt-4 space-y-3">
                {upcomingMatches.slice(0, 3).map((m) => (
                  <li>
                    <a
                      href={`/matches/${m.slug}`}
                      class="block rounded-xl border border-gray-500/20 bg-dark p-4 hover:shadow-sm transition"
                    >
                      <div class="flex items-start justify-between gap-3">
                        <div>
                          <div class="flex flex-wrap items-center gap-2">
                            <span class="text-sm font-semibold text-page">{m.data.team}</span>
                            <span class="rounded-full border border-gray-500/20 px-2 py-0.5 text-xs text-muted">
                              {homeAwayLabel(m.data.homeAway)}
                            </span>
                            {relativeLabel(m.data.matchDate) ? (
                              <span class="rounded-full border border-gray-500/20 px-2 py-0.5 text-xs text-muted">
                                {relativeLabel(m.data.matchDate)}
                              </span>
                            ) : null}
                          </div>

                          <div class="mt-1 text-sm text-muted">
                            {formatShortDate(m.data.matchDate)} · vs. {m.data.opponent}
                            {m.data.location ? ` · ${m.data.location}` : ''}
                          </div>
                        </div>

                        {m.data.result ? (
                          <div class="shrink-0 text-sm font-semibold text-page whitespace-nowrap">{m.data.result}</div>
                        ) : null}
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
        </div>

        <!-- Events Card -->
        <div class="rounded-2xl border border-gray-500/20 bg-light p-5">
          <div class="flex items-center justify-between gap-3">
            <h3 class="font-semibold text-page">Nächste Termine</h3>
            <a class="text-sm text-muted hover:underline" href="/events">Alle Termine →</a>
          </div>

          {
            upcomingEvents.length === 0 ? (
              <div class="mt-3">
                <p class="text-muted text-sm leading-relaxed">Aktuell sind keine Termine veröffentlicht.</p>
                <div class="mt-4">
                  <a class="btn btn-secondary" href="/contact">
                    Termin vorschlagen
                  </a>
                </div>
              </div>
            ) : (
              <ul class="mt-4 space-y-3">
                {upcomingEvents.slice(0, 3).map((e) => (
                  <li>
                    <a
                      href={`/events/${e.slug}`}
                      class="block rounded-xl border border-gray-500/20 bg-dark p-4 hover:shadow-sm transition"
                    >
                      <div class="flex items-start justify-between gap-3">
                        <div>
                          <div class="flex flex-wrap items-center gap-2">
                            <span class="text-sm font-semibold text-page">{e.data.title}</span>
                            {relativeLabel(e.data.startDate) ? (
                              <span class="rounded-full border border-gray-500/20 px-2 py-0.5 text-xs text-muted">
                                {relativeLabel(e.data.startDate)}
                              </span>
                            ) : null}
                          </div>

                          <div class="mt-1 text-sm text-muted">
                            {formatShortDate(e.data.startDate)}
                            {e.data.location ? ` · ${e.data.location}` : ''}
                          </div>
                        </div>

                        {e.data.time ? (
                          <div class="shrink-0 text-sm text-muted whitespace-nowrap">{e.data.time}</div>
                        ) : null}
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
        </div>
      </div>
    </div>

    <!-- Latest Posts Preview -->
    <div>
      <div class="flex items-center justify-between gap-3 mb-4">
        <h2 class="text-2xl font-semibold">Neueste Posts</h2>
        <a class="text-sm text-muted hover:underline" href="/posts">Alle Posts →</a>
      </div>

      {
        latestPosts.length === 0 ? (
          <div class="rounded-2xl border border-gray-500/20 bg-light p-6">
            <p class="text-muted text-sm">Noch keine Posts vorhanden.</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {latestPosts.map((p) => (
              <a
                href={`/posts/${p.slug}`}
                class="block rounded-2xl border border-gray-500/20 bg-light p-5 hover:shadow-sm transition"
              >
                <div class="text-sm text-muted">{formatShortDate(p.data.date)}</div>
                <h3 class="font-semibold text-page mt-1">{p.data.title}</h3>
                {p.data.excerpt ? (
                  <p class="text-muted mt-2 text-sm leading-relaxed line-clamp-3">{p.data.excerpt}</p>
                ) : null}

                {p.data.gallery?.length ? (
                  <div class="mt-4 text-xs text-muted">{p.data.gallery.length} Fotos</div>
                ) : null}

                {p.data.tags?.length ? (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {p.data.tags.slice(0, 3).map((t) => (
                      <span class="rounded-full border border-gray-500/20 bg-dark px-3 py-1 text-xs text-muted">
                        {t}
                      </span>
                    ))}
                  </div>
                ) : null}
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- Core areas -->
  <Features
    id="core"
    tagline="Verein"
    title="Alles Wichtige für Mitglieder und Gäste"
    subtitle="Schnell finden, was du brauchst – von Spielterminen bis zur Platzbuchung."
    items={[
      {
        title: 'Spielbetrieb',
        description: 'Begegnungen, Teams und Ergebnisse.',
        icon: 'tabler:trophy',
      },
      {
        title: 'Events',
        description: 'Turniere, Arbeitseinsätze, Feste und Termine.',
        icon: 'tabler:calendar-event',
      },
      {
        title: 'Platzbuchung',
        description: 'Plätze reservieren und Buchungsregeln einsehen.',
        icon: 'tabler:calendar-check',
      },
      {
        title: 'Mitgliedschaft',
        description: 'Beiträge, Aufnahme und Ansprechpartner.',
        icon: 'tabler:id-badge-2',
      },
      {
        title: 'Anlage & Anfahrt',
        description: 'Adresse, Parken, Plätze und Clubheim.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Kontakt',
        description: 'So erreichst du uns schnell.',
        icon: 'tabler:mail',
      },
    ]}
  />

  <!-- Quick Links (falls Features nicht klickbar ist) -->
  <section class="max-w-5xl mx-auto px-4 pb-10">
    <div class="rounded-2xl border border-gray-500/20 bg-dark p-6">
      <h2 class="text-xl font-semibold">Schnellzugriff</h2>
      <p class="text-muted mt-2 text-sm">Direkt zu den wichtigsten Bereichen.</p>

      <div class="mt-4 flex flex-col sm:flex-row flex-wrap gap-3">
        <a class="btn btn-secondary" href="/matches">Spielbetrieb</a>
        <a class="btn btn-secondary" href="/events">Events</a>
        <a class="btn btn-secondary" href="/guest-players">Platz buchen</a>
        <a class="btn btn-secondary" href="/membership">Mitglied werden</a>
        <a class="btn btn-secondary" href="/facility">Anlage</a>
        <a class="btn btn-secondary" href="/contact">Kontakt</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CallToAction
    actions={[
      { variant: 'primary', text: 'Platz buchen', href: '/guest-players', icon: 'tabler:calendar' },
      { text: 'Kontakt', href: '/contact' },
    ]}
  >
    <Fragment slot="title"> Lust auf ein Match? </Fragment>

    <Fragment slot="subtitle"> Buche deinen Platz online oder melde dich bei Fragen direkt bei uns. </Fragment>
  </CallToAction>
</Layout>
