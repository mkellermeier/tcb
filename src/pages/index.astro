---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { getCollection } from 'astro:content';

const metadata = {
  title: 'TC Schwarzwald',
  ignoreTitleTemplate: true,
  description: 'Spielbetrieb, Termine, Platzbuchung und Vereinsinfos.',
};

const now = new Date();

// Load upcoming matches
const matches = (await getCollection('matches'))
  .filter((m) => !m.data.draft)
  .sort((a, b) => +a.data.matchDate - +b.data.matchDate);

const upcomingMatches = matches.filter((m) => m.data.matchDate >= now).slice(0, 5);

// Load upcoming events
const events = (await getCollection('events'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => +a.data.startDate - +b.data.startDate);

const upcomingEvents = events.filter((e) => e.data.startDate >= now).slice(0, 5);

function formatShortDate(d: Date) {
  return d.toLocaleDateString('de-DE', { weekday: 'short', day: '2-digit', month: '2-digit' });
}

function homeAwayLabel(v: 'home' | 'away') {
  return v === 'home' ? 'Heim' : 'Auswärts';
}

const matchesTeaser = upcomingMatches
  .map(
    (m) =>
      `${formatShortDate(m.data.matchDate)} · ${m.data.team} (${homeAwayLabel(m.data.homeAway)} vs. ${m.data.opponent})`
  )
  .slice(0, 3);

const eventsTeaser = upcomingEvents
  .map((e) => `${formatShortDate(e.data.startDate)} · ${e.data.title}${e.data.location ? ` (${e.data.location})` : ''}`)
  .slice(0, 3);
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero
    actions={[
      { variant: 'primary', text: 'Platz buchen', href: '/booking', icon: 'tabler:calendar' },
      { text: 'Mitglied werden', href: '/membership' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Tennis im Schwarzwald' }}
  >
    <Fragment slot="title">
      Tennis im <span class="text-accent dark:text-white">Schwarzwald</span>
    </Fragment>

    <Fragment slot="subtitle">
      Spielbetrieb, Termine und Vereinsinfos – alles an einem Ort.
    </Fragment>
  </Hero>

  <!-- Quick info (Content widget used as a clean 2-column block) -->
  <Content
    isReversed={false}
    tagline="Aktuelles"
    title="Die nächsten Termine auf einen Blick"
    items={[
      {
        title: 'Nächste Spiele',
        description:
          matchesTeaser.length > 0
            ? matchesTeaser.join('\n')
            : 'Aktuell sind keine Spiele eingetragen.',
      },
      {
        title: 'Nächste Events',
        description:
          eventsTeaser.length > 0
            ? eventsTeaser.join('\n')
            : 'Aktuell sind keine Termine veröffentlicht.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1521412644187-c49fa049e84d?auto=format&fit=crop&w=1600&q=80',
      alt: 'Tennis',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Willkommen beim TC Schwarzwald</h3>
      <p class="text-muted">
        Hier findest du Medenspiele, Veranstaltungen und die wichtigsten Infos rund um unseren Verein.
      </p>

      <div class="mt-6 flex flex-col sm:flex-row gap-3">
        <a class="btn btn-secondary" href="/matches">Zum Spielbetrieb</a>
        <a class="btn btn-secondary" href="/events">Zu den Events</a>
      </div>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Core areas -->
  <Features
    id="core"
    tagline="Verein"
    title="Alles Wichtige für Mitglieder und Gäste"
    subtitle="Schnell finden, was du brauchst – von Spielterminen bis zur Platzbuchung."
    items={[
      {
        title: 'Spielbetrieb',
        description: 'Begegnungen, Teams und Ergebnisse.',
        icon: 'tabler:trophy',
      },
      {
        title: 'Events',
        description: 'Turniere, Arbeitseinsätze, Feste und Termine.',
        icon: 'tabler:calendar-event',
      },
      {
        title: 'Platzbuchung',
        description: 'Plätze reservieren und Buchungsregeln einsehen.',
        icon: 'tabler:calendar-check',
      },
      {
        title: 'Mitgliedschaft',
        description: 'Beiträge, Aufnahme und Ansprechpartner.',
        icon: 'tabler:id-badge-2',
      },
      {
        title: 'Anlage & Anfahrt',
        description: 'Adresse, Parken, Plätze und Clubheim.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Kontakt',
        description: 'So erreichst du uns schnell.',
        icon: 'tabler:mail',
      },
    ]}
  />

  <!-- CTA -->
  <CallToAction
    actions={[
      { variant: 'primary', text: 'Platz buchen', href: '/booking', icon: 'tabler:calendar' },
      { text: 'Kontakt', href: '/contact' },
    ]}
  >
    <Fragment slot="title">
      Lust auf ein Match?
    </Fragment>

    <Fragment slot="subtitle">
      Buche deinen Platz online oder melde dich bei Fragen direkt bei uns.
    </Fragment>
  </CallToAction>
</Layout>