---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import defaultPostImage from '~/assets/images/hero-blackforest.png';

const metadata = {
  title: 'TC Bühlertal',
  ignoreTitleTemplate: true,
  description: 'Spielbetrieb, Termine, Platzbuchung und Vereinsinfos.',
};

const now = new Date();

// ---------- helpers ----------
function formatShortDate(d: Date) {
  return d.toLocaleDateString('de-DE', { weekday: 'short', day: '2-digit', month: '2-digit' });
}

function formatPostDate(d: Date) {
  return d.toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' });
}

function daysBetween(a: Date, b: Date) {
  const da = new Date(a.getFullYear(), a.getMonth(), a.getDate()).getTime();
  const db = new Date(b.getFullYear(), b.getMonth(), b.getDate()).getTime();
  return Math.round((db - da) / (1000 * 60 * 60 * 24));
}

function relativeLabel(d: Date) {
  const diff = daysBetween(now, d);
  if (diff === 0) return 'Heute';
  if (diff === 1) return 'Morgen';
  if (diff > 1 && diff <= 7) return `in ${diff} Tagen`;
  return '';
}

function homeAwayLabel(v: 'home' | 'away') {
  return v === 'home' ? 'Heim' : 'Auswärts';
}

// ---------- matches ----------
const matchesAll = (await getCollection('matches', ({ data }) => !data.draft)).sort(
  (a, b) => +a.data.matchDate - +b.data.matchDate
);

const upcomingMatches = matchesAll.filter((m) => m.data.matchDate >= now).slice(0, 3);
const recentMatches = matchesAll
  .filter((m) => m.data.matchDate < now)
  .slice(-3)
  .reverse();

// ---------- events ----------
const eventsAll = (await getCollection('events', ({ data }) => !data.draft)).sort(
  (a, b) => +a.data.startDate - +b.data.startDate
);

const upcomingEvents = eventsAll.filter((e) => e.data.startDate >= now).slice(0, 3);

// ---------- latest posts ----------
const postsAll = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const latestPosts = postsAll.slice(0, 3);
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      { variant: 'primary', text: 'Spiele & Ergebnisse', href: '/matches', icon: 'tabler:trophy' },
      { text: 'Termine', href: '/events', icon: 'tabler:calendar-event' },
    ]}
    image={{ src: '~/assets/images/court-overview.png', alt: 'Tennis im Schwarzwald' }}
  >
    <Fragment slot="title">
      Tennis im <span class="text-accent dark:text-white">Schwarzwald</span>
    </Fragment>
    <Fragment slot="subtitle">Willkommen beim TC Bühlertal – eurem Tennisclub seit 1965.</Fragment>
  </Hero>

  <section class="max-w-5xl mx-auto px-4 py-10 space-y-10">
    <!-- Stat bar -->
    <div
      class="flex flex-wrap items-center justify-between gap-4 rounded-2xl border border-gray-500/20 bg-light px-6 py-4"
    >
      <div class="flex flex-wrap gap-6 text-sm">
        <div class="flex items-center gap-2">
          <Icon name="tabler:calendar" class="w-4 h-4 text-primary shrink-0" />
          <span class="font-semibold text-page">1965</span>
          <span class="text-muted">gegründet</span>
        </div>
        <div class="hidden sm:block w-px bg-gray-500/20 self-stretch"></div>
        <div class="flex items-center gap-2">
          <Icon name="tabler:ball-tennis" class="w-4 h-4 text-primary shrink-0" />
          <span class="font-semibold text-page">6</span>
          <span class="text-muted">Sandplätze</span>
        </div>
        <div class="hidden sm:block w-px bg-gray-500/20 self-stretch"></div>
        <div class="flex items-center gap-2">
          <Icon name="tabler:home" class="w-4 h-4 text-primary shrink-0" />
          <span class="text-muted">Clubhaus & Terrasse</span>
        </div>
        <div class="hidden sm:block w-px bg-gray-500/20 self-stretch"></div>
        <div class="flex items-center gap-2">
          <Icon name="tabler:map-pin" class="w-4 h-4 text-primary shrink-0" />
          <span class="font-semibold text-page">Bühlertal</span>
          <span class="text-muted">Schwarzwald</span>
        </div>
      </div>
      <a href="/club" class="text-sm text-primary hover:underline whitespace-nowrap">Mehr über uns →</a>
    </div>

    <!-- Aktuelles -->
    <div>
      <h2 class="text-2xl font-semibold mb-4">Aktuelles</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Nächste Spiele -->
        <div class="rounded-2xl border border-gray-500/20 bg-light p-5">
          <div class="flex items-center justify-between gap-3 mb-4">
            <div class="flex items-center gap-2">
              <Icon name="tabler:trophy" class="w-5 h-5 text-primary shrink-0" />
              <h3 class="font-semibold text-page">
                {upcomingMatches.length > 0 ? 'Nächste Spiele' : 'Letzte Ergebnisse'}
              </h3>
            </div>
            <a class="text-sm text-primary hover:underline" href="/matches">Alle Spiele →</a>
          </div>

          {
            upcomingMatches.length === 0 && recentMatches.length === 0 ? (
              <div>
                <p class="text-muted text-sm leading-relaxed">Noch keine Spiele veröffentlicht.</p>
              </div>
            ) : (
              <ul class="space-y-2">
                {(upcomingMatches.length > 0 ? upcomingMatches : recentMatches).map((m) => (
                  <li class="flex items-start justify-between gap-3 rounded-xl border border-gray-500/20 bg-dark p-4">
                    <div>
                      <div class="flex flex-wrap items-center gap-2">
                        <span class="text-sm font-semibold text-page">{m.data.team}</span>
                        <span class="rounded-full border border-gray-500/20 px-2 py-0.5 text-xs text-muted">
                          {homeAwayLabel(m.data.homeAway)}
                        </span>
                        {relativeLabel(m.data.matchDate) && (
                          <span class="rounded-full bg-primary/10 border border-primary/20 px-2 py-0.5 text-xs text-primary">
                            {relativeLabel(m.data.matchDate)}
                          </span>
                        )}
                      </div>
                      <div class="mt-1 text-sm text-muted">
                        {formatShortDate(m.data.matchDate)} · vs. {m.data.opponent}
                        {m.data.location ? ` · ${m.data.location}` : ''}
                      </div>
                    </div>
                    {m.data.result && (
                      <span class="shrink-0 text-sm font-semibold text-page whitespace-nowrap">{m.data.result}</span>
                    )}
                  </li>
                ))}
              </ul>
            )
          }
        </div>

        <!-- Nächste Termine -->
        <div class="rounded-2xl border border-gray-500/20 bg-light p-5">
          <div class="flex items-center justify-between gap-3 mb-4">
            <div class="flex items-center gap-2">
              <Icon name="tabler:calendar-event" class="w-5 h-5 text-primary shrink-0" />
              <h3 class="font-semibold text-page">Nächste Termine</h3>
            </div>
            <a class="text-sm text-primary hover:underline" href="/events">Alle Termine →</a>
          </div>

          {
            upcomingEvents.length === 0 ? (
              <div>
                <p class="text-muted text-sm leading-relaxed">Aktuell sind keine Termine veröffentlicht.</p>
                <a class="btn btn-secondary mt-4 inline-block" href="/contact">
                  Termin vorschlagen
                </a>
              </div>
            ) : (
              <ul class="space-y-2">
                {upcomingEvents.map((e) => (
                  <li>
                    <a
                      href={`/events/${e.slug}`}
                      class="flex items-start justify-between gap-3 rounded-xl border border-gray-500/20 bg-dark p-4 hover:border-gray-400/40 hover:bg-white/5 transition"
                    >
                      <div>
                        <div class="flex flex-wrap items-center gap-2">
                          <span class="text-sm font-semibold text-page">{e.data.title}</span>
                          {relativeLabel(e.data.startDate) && (
                            <span class="rounded-full bg-primary/10 border border-primary/20 px-2 py-0.5 text-xs text-primary">
                              {relativeLabel(e.data.startDate)}
                            </span>
                          )}
                        </div>
                        <div class="mt-1 text-sm text-muted">
                          {formatShortDate(e.data.startDate)}
                          {e.data.location ? ` · ${e.data.location}` : ''}
                        </div>
                      </div>
                      {e.data.time && (
                        <span class="shrink-0 text-sm text-muted whitespace-nowrap">{e.data.time} Uhr</span>
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
        </div>
      </div>
    </div>

    <!-- Neueste Berichte -->
    <div>
      <div class="flex items-center justify-between gap-3 mb-4">
        <h2 class="text-2xl font-semibold">Neueste Berichte</h2>
        <a class="text-sm text-primary hover:underline" href="/posts">Alle Berichte →</a>
      </div>

      {
        latestPosts.length === 0 ? (
          <div class="rounded-2xl border border-gray-500/20 bg-light p-6">
            <p class="text-muted text-sm">Noch keine Berichte vorhanden.</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {latestPosts.map((p) => {
              const previewImg = p.data.coverImage ?? p.data.gallery?.[0]?.src ?? defaultPostImage.src;
              return (
                <a
                  href={`/posts/${p.slug}`}
                  class="group flex flex-col rounded-2xl border border-gray-500/20 bg-light overflow-hidden hover:border-gray-400/40 hover:shadow-md transition"
                >
                  <div class="overflow-hidden">
                    <img
                      src={previewImg}
                      alt={p.data.title}
                      loading="lazy"
                      class="h-40 w-full object-cover transition duration-300 group-hover:scale-[1.04]"
                    />
                  </div>
                  <div class="p-4 flex flex-col flex-1">
                    <div class="text-xs text-muted mb-1">{formatPostDate(p.data.date)}</div>
                    <h3 class="font-semibold text-page leading-snug">{p.data.title}</h3>
                    {p.data.excerpt && (
                      <p class="text-muted mt-2 text-sm leading-relaxed line-clamp-2 flex-1">{p.data.excerpt}</p>
                    )}
                    {p.data.tags?.length ? (
                      <div class="mt-3 flex flex-wrap gap-1">
                        {p.data.tags.slice(0, 2).map((t) => (
                          <span class="rounded-full border border-gray-500/20 bg-dark px-2 py-0.5 text-xs text-muted">
                            {t}
                          </span>
                        ))}
                      </div>
                    ) : null}
                  </div>
                </a>
              );
            })}
          </div>
        )
      }
    </div>
  </section>

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Platz buchen', href: '/guest-players', icon: 'tabler:calendar' },
      { text: 'Mitglied werden', href: '/membership', icon: 'tabler:user-plus' },
      { text: 'Kontakt', href: '/contact' },
    ]}
  >
    <Fragment slot="title">Lust auf ein Match?</Fragment>
    <Fragment slot="subtitle"
      >Buche deinen Platz online, werde Mitglied oder melde dich bei Fragen direkt bei uns.</Fragment
    >
  </CallToAction>
</Layout>
