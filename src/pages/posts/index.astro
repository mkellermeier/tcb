---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import { getCollection } from 'astro:content';
import defaultPostImage from '~/assets/images/bag-on-clay.png';

const metadata = {
  title: 'Berichte',
  description: 'Rückblicke, Vereinsleben und Spielberichte beim TC Bühlertal.',
};

const entries = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const fmt = (d: Date) => new Intl.DateTimeFormat('de-DE', { day: '2-digit', month: 'long', year: 'numeric' }).format(d);
---

<Layout metadata={metadata}>
  <Hero
    image={{
      src: '~/assets/images/bag-on-clay.png',
      alt: 'Berichte beim TC Bühlertal',
    }}
  >
    <Fragment slot="title">Berichte</Fragment>
    <Fragment slot="subtitle">Rückblicke, Vereinsleben und Spielberichte – alles, was bei uns passiert ist.</Fragment>
  </Hero>

  <section class="max-w-5xl mx-auto px-4 py-10">
    {
      entries.length === 0 ? (
        <div class="rounded-2xl border border-gray-500/20 bg-light p-10 text-center">
          <p class="text-muted text-lg font-medium">Noch keine Berichte vorhanden.</p>
          <p class="text-muted text-sm mt-2">Schau bald wieder vorbei!</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {entries.map((e) => (
            <a
              href={`/posts/${e.slug}`}
              class="group flex flex-col rounded-2xl border border-gray-500/20 bg-light overflow-hidden hover:shadow-md transition"
            >
              <div class="overflow-hidden">
                <img
                  src={e.data.coverImage ?? e.data.gallery?.[0]?.src ?? defaultPostImage.src}
                  alt={e.data.title}
                  loading="lazy"
                  class="h-48 w-full object-cover transition duration-200 group-hover:scale-[1.02]"
                />
              </div>

              <div class="p-5 flex flex-col flex-1">
                <div class="flex items-center justify-between gap-3 text-xs text-muted mb-2">
                  <span>{fmt(e.data.date)}</span>
                  {e.data.gallery?.length ? <span>{e.data.gallery.length} Fotos</span> : null}
                </div>

                <h2 class="font-semibold text-page text-lg leading-snug">{e.data.title}</h2>

                {e.data.excerpt ? (
                  <p class="text-muted mt-2 text-sm leading-relaxed line-clamp-3 flex-1">{e.data.excerpt}</p>
                ) : (
                  <div class="flex-1" />
                )}

                {e.data.tags?.length ? (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {e.data.tags.slice(0, 3).map((t) => (
                      <span class="rounded-full border border-gray-500/20 bg-dark px-3 py-1 text-xs text-muted">
                        {t}
                      </span>
                    ))}
                  </div>
                ) : null}
              </div>
            </a>
          ))}
        </div>
      )
    }
  </section>
</Layout>
