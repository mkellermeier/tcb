---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Gallery from '../../components/common/Gallery.astro'; // oder ~/... wenn Alias existiert
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('posts', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const metadata = {
  title: entry.data.title,
  description: entry.data.excerpt ?? 'Beitrag',
};

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('de-DE', { day: '2-digit', month: 'long', year: 'numeric' }).format(d);
---

<Layout metadata={metadata}>
  <Hero
    image={{
      src: entry.data.coverImage ? entry.data.coverImage : '~/assets/images/bag-on-clay.png',
      alt: entry.data.title,
    }}
  >
    <Fragment slot="title">{entry.data.title}</Fragment>
    <Fragment slot="subtitle">
      {entry.data.excerpt ?? fmt(entry.data.date)}
    </Fragment>
  </Hero>

  <section class="max-w-5xl mx-auto px-4 py-10 space-y-10">
    <!-- Back -->
    <div>
      <a class="btn btn-secondary" href="/posts">← Zurück zu den Beiträgen</a>
    </div>

    <!-- Meta box -->
    <div class="rounded-2xl border border-gray-500/20 bg-light p-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
        <div>
          <div class="text-muted">Datum</div>
          <div class="font-semibold text-page">{fmt(entry.data.date)}</div>
        </div>

        {entry.data.tags?.length ? (
          <div>
            <div class="text-muted">Tags</div>
            <div class="mt-2 flex flex-wrap gap-2">
              {entry.data.tags.map((t) => (
                <span class="rounded-full border border-gray-500/20 bg-dark px-3 py-1 text-xs text-muted">
                  {t}
                </span>
              ))}
            </div>
          </div>
        ) : null}
      </div>

      {entry.data.meta?.length ? (
        <div class="mt-6 border-t border-gray-500/20 pt-4 space-y-2">
          {entry.data.meta.map((m) => (
            <div class="flex gap-3">
              <div class="w-28 shrink-0 text-muted">{m.label}</div>
              <div class="text-page">{m.value}</div>
            </div>
          ))}
        </div>
      ) : null}
    </div>

    <!-- Content -->
    <div class="rounded-2xl border border-gray-500/20 bg-light p-6">
      <article class="prose dark:prose-invert max-w-none">
        <Content />
      </article>
    </div>

    <!-- Gallery -->
    {entry.data.gallery?.length ? (
      <div class="rounded-2xl border border-gray-500/20 bg-light p-6">
        <Gallery items={entry.data.gallery} />
      </div>
    ) : null}
  </section>
</Layout>