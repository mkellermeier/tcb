---
import Layout from '~/layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';

export async function getStaticPaths() {
  const entries = await getCollection('matches', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const d = entry.data;

const title = `${d.team} – ${d.homeAway === 'home' ? 'Heim' : 'Auswärts'} vs. ${d.opponent}`;

const metadata = {
  title,
  description: `${d.team} vs. ${d.opponent} am ${d.matchDate.toLocaleDateString('de-DE')}`,
};

const fmtLong = (date: Date) =>
  date.toLocaleDateString('de-DE', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' });

const fmtTime = (date: Date) =>
  date.toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' });

const hasTime = d.matchDate.getHours() !== 0 || d.matchDate.getMinutes() !== 0;
---

<Layout metadata={metadata}>
  <section class="max-w-3xl mx-auto px-4 py-12 space-y-6">
    <div>
      <a class="btn btn-secondary" href="/matches">← Zurück zur Übersicht</a>
    </div>

    <div class="rounded-2xl border border-gray-500/20 bg-light p-6 space-y-6">
      <div>
        <div class="flex flex-wrap items-center gap-2 mb-2">
          <span class="text-xs rounded-full border border-gray-500/20 bg-dark px-3 py-1 text-muted">
            {d.homeAway === 'home' ? 'Heimspiel' : 'Auswärtsspiel'}
          </span>
          {d.competition && (
            <span class="text-xs rounded-full border border-gray-500/20 bg-dark px-3 py-1 text-muted">
              {d.competition}
            </span>
          )}
        </div>
        <h1 class="text-2xl font-bold text-page leading-snug">{d.team}</h1>
        <p class="text-muted mt-1 text-lg">vs. {d.opponent}</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm border-t border-gray-500/20 pt-5">
        <div class="flex items-start gap-3">
          <Icon name="tabler:calendar" class="w-5 h-5 text-primary mt-0.5 shrink-0" />
          <div>
            <div class="text-muted">Datum</div>
            <div class="text-page font-medium">
              {fmtLong(d.matchDate)}
              {hasTime ? ` · ${fmtTime(d.matchDate)} Uhr` : ''}
            </div>
          </div>
        </div>

        {d.location && (
          <div class="flex items-start gap-3">
            <Icon name="tabler:map-pin" class="w-5 h-5 text-primary mt-0.5 shrink-0" />
            <div>
              <div class="text-muted">Ort</div>
              <div class="text-page font-medium">{d.location}</div>
            </div>
          </div>
        )}

        <div class="flex items-start gap-3">
          <Icon name="tabler:trophy" class="w-5 h-5 text-primary mt-0.5 shrink-0" />
          <div>
            <div class="text-muted">Ergebnis</div>
            <div class="text-page font-medium">
              {d.result ? d.result : 'Noch nicht gespielt'}
            </div>
          </div>
        </div>

        {d.detailsUrl && (
          <div class="flex items-start gap-3">
            <Icon name="tabler:external-link" class="w-5 h-5 text-primary mt-0.5 shrink-0" />
            <div>
              <div class="text-muted">Verband</div>
              <a
                href={d.detailsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-primary hover:underline font-medium"
              >
                Offizielle Seite →
              </a>
            </div>
          </div>
        )}
      </div>
    </div>

    {entry.body?.trim() && (
      <div class="rounded-2xl border border-gray-500/20 bg-light p-6">
        <article class="prose dark:prose-invert max-w-none">
          <Content />
        </article>
      </div>
    )}
  </section>
</Layout>
