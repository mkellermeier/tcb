---
import { getCollection } from 'astro:content';

const allMatches = (await getCollection('matches'))
  .filter((m) => !m.data.draft)
  .sort((a, b) => +a.data.matchDate - +b.data.matchDate);

const now = new Date();
const upcomingMatches = allMatches.filter((m) => m.data.matchDate >= now).slice(0, 10);

// Group by team
const matchesByTeam = new Map<string, typeof allMatches>();
for (const match of allMatches) {
  const team = match.data.team;
  matchesByTeam.set(team, [...(matchesByTeam.get(team) ?? []), match]);
}

function formatDate(d: Date) {
  return d.toLocaleDateString('de-DE', { weekday: 'short', year: 'numeric', month: '2-digit', day: '2-digit' });
}

function homeAwayLabel(v: 'home' | 'away') {
  return v === 'home' ? 'Heim' : 'Auswärts';
}
---

<html lang="de">
  <head>
    <title>Spielbetrieb</title>
  </head>

  <body class="bg-page text-page">
    <main class="max-w-5xl mx-auto px-4 py-10">
      <header class="mb-8">
        <h1 class="text-3xl font-semibold">Spielbetrieb</h1>
        <p class="text-muted mt-2">
          Spieltermine und Ergebnisse unserer Teams.
        </p>
      </header>

      <section class="mb-12">
        <h2 class="text-xl font-semibold mb-3">Nächste Spiele</h2>

        {upcomingMatches.length === 0 ? (
          <p class="text-muted">Aktuell sind keine Spiele eingetragen.</p>
        ) : (
          <ul class="space-y-3">
            {upcomingMatches.map((m) => (
              <li class="p-4 rounded-2xl border border-gray-500/20 bg-light">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                  <div>
                    <div class="font-semibold">{m.data.team}</div>
                    <div class="text-sm text-muted">
                      {formatDate(m.data.matchDate)} • {homeAwayLabel(m.data.homeAway)} vs. {m.data.opponent}
                      {m.data.location ? ` • ${m.data.location}` : ''}
                    </div>
                    {m.data.competition && (
                      <div class="text-sm text-muted">{m.data.competition}</div>
                    )}
                  </div>

                  {m.data.detailsUrl ? (
                    <a class="btn btn-secondary" href={m.data.detailsUrl} target="_blank" rel="noopener">
                      Details
                    </a>
                  ) : null}
                </div>
              </li>
            ))}
          </ul>
        )}
      </section>

      <section class="space-y-10">
        {[...matchesByTeam.entries()].map(([team, matches]) => (
          <div>
            <h2 class="text-xl font-semibold mb-3">{team}</h2>

            <div class="overflow-x-auto rounded-2xl border border-gray-500/20">
              <table class="w-full text-sm">
                <thead class="bg-dark">
                  <tr>
                    <th class="text-left p-3 whitespace-nowrap">Datum</th>
                    <th class="text-left p-3">Begegnung</th>
                    <th class="text-left p-3">Ort</th>
                    <th class="text-left p-3 whitespace-nowrap">Ergebnis</th>
                    <th class="text-left p-3 whitespace-nowrap">Link</th>
                  </tr>
                </thead>
                <tbody>
                  {matches.map((m) => (
                    <tr class="border-t border-gray-500/20">
                      <td class="p-3 whitespace-nowrap">{formatDate(m.data.matchDate)}</td>
                      <td class="p-3">
                        {homeAwayLabel(m.data.homeAway)} vs. {m.data.opponent}
                        {m.data.competition ? <span class="text-muted"> · {m.data.competition}</span> : null}
                      </td>
                      <td class="p-3">{m.data.location ?? '—'}</td>
                      <td class="p-3 whitespace-nowrap">{m.data.result ?? '—'}</td>
                      <td class="p-3 whitespace-nowrap">
                        {m.data.detailsUrl ? (
                          <a class="hover:underline" href={m.data.detailsUrl} target="_blank" rel="noopener">
                            Details
                          </a>
                        ) : (
                          '—'
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </section>
    </main>
  </body>
</html>