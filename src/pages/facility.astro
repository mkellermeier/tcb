---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: 'Anlage & Anfahrt',
  description: 'Die Tennisanlage des TC Bühlertal – Plätze, Clubhaus, Adresse und Anfahrt.',
};
---

<Layout metadata={metadata}>
  <Hero
    image={{
      src: '~/assets/images/clean-court.png',
      alt: 'Tennisanlage TC Bühlertal',
    }}
  >
    <Fragment slot="title">Anlage & Anfahrt</Fragment>
    <Fragment slot="subtitle">
      Sechs Sandplätze, Clubhaus mit Terrasse und eine einladende Atmosphäre mitten im Schwarzwald.
    </Fragment>
  </Hero>

  <section class="max-w-5xl mx-auto px-4 py-10 space-y-10">
    <!-- Adresse & Anfahrt -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="rounded-2xl border border-gray-500/20 bg-light p-6">
        <h2 class="text-xl font-semibold">Adresse</h2>
        <address class="mt-4 not-italic text-muted text-sm leading-relaxed space-y-1">
          <div class="font-semibold text-page">TC Bühlertal e.V.</div>
          <div>Bühlertal</div>
          <div>Baden-Württemberg</div>
        </address>

        <div class="mt-5 flex flex-col gap-2">
          <a
            class="btn btn-secondary"
            href="https://www.google.com/maps/search/TC+B%C3%BChlertal"
            target="_blank"
            rel="noopener"
          >
            In Google Maps öffnen
          </a>
        </div>
      </div>

      <div class="rounded-2xl border border-gray-500/20 bg-light p-6">
        <h2 class="text-xl font-semibold">Anfahrt</h2>
        <div class="mt-4 space-y-3 text-sm text-muted leading-relaxed">
          <div>
            <div class="font-semibold text-page">Mit dem Auto</div>
            <p class="mt-1">Über die B500 Richtung Bühlertal. Parkplätze direkt an der Anlage vorhanden.</p>
          </div>
          <div>
            <div class="font-semibold text-page">Mit dem Bus</div>
            <p class="mt-1">Bushaltestelle in der Nähe der Anlage. Fahrpläne unter kvv.de.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Plätze -->
    <div>
      <h2 class="text-2xl font-semibold mb-4">Unsere Plätze</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="rounded-2xl border border-gray-500/20 bg-light p-5 text-center">
          <div class="text-3xl font-bold text-page">6</div>
          <div class="text-muted text-sm mt-1">Sandplätze</div>
        </div>
        <div class="rounded-2xl border border-gray-500/20 bg-light p-5 text-center">
          <div class="text-3xl font-bold text-page">1965</div>
          <div class="text-muted text-sm mt-1">Gegründet</div>
        </div>
        <div class="rounded-2xl border border-gray-500/20 bg-light p-5 text-center">
          <div class="text-3xl font-bold text-page">∞</div>
          <div class="text-muted text-sm mt-1">Schwarzwaldluft</div>
        </div>
      </div>

      <div class="mt-4 rounded-2xl border border-gray-500/20 bg-light p-5">
        <p class="text-muted text-sm leading-relaxed">
          Alle sechs Plätze sind Sandplätze und werden regelmäßig gepflegt. Die Spielsaison läuft in der Regel
          von <span class="text-page font-medium">April bis Oktober</span>, je nach Witterung.
        </p>
      </div>
    </div>

    <!-- Clubhaus -->
    <div>
      <h2 class="text-2xl font-semibold mb-4">Clubhaus & Terrasse</h2>
      <div class="rounded-2xl border border-gray-500/20 bg-light p-6">
        <p class="text-muted text-sm leading-relaxed">
          Unser Clubhaus bietet einen gemütlichen Rückzugsort mit großer Terrasse direkt an den Plätzen.
          Ideal für Pausen, geselliges Beisammensein und Vereinsveranstaltungen.
        </p>
      </div>
    </div>

    <!-- Platzregeln -->
    <div>
      <h2 class="text-2xl font-semibold mb-4">Platzregeln</h2>
      <div class="rounded-2xl border border-gray-500/20 bg-dark p-6">
        <ul class="text-sm text-muted space-y-2 list-disc list-inside">
          <li>Tennisschuhe mit Sohle für Sandplätze sind Pflicht</li>
          <li>Plätze nach dem Spiel abziehen und in ordentlichem Zustand hinterlassen</li>
          <li>Spielzeit bei Gastspielen: 90 Minuten</li>
          <li>Mitglieder haben Vorrang bei Platzbelegung</li>
          <li>Hunde sind auf der Anlage nicht erlaubt</li>
          <li>Abfall bitte in den vorgesehenen Behältern entsorgen</li>
        </ul>
      </div>
    </div>

    <!-- CTA -->
    <div class="rounded-2xl border border-gray-500/20 bg-light p-6 flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between">
      <div>
        <h3 class="font-semibold text-page">Interesse an einem Schnuppertraining?</h3>
        <p class="text-muted text-sm mt-1">Komm einfach vorbei oder schreib uns vorher kurz.</p>
      </div>
      <div class="flex gap-3 flex-wrap">
        <a class="btn btn-primary" href="/contact">Kontakt</a>
        <a class="btn btn-secondary" href="/membership">Mitglied werden</a>
      </div>
    </div>
  </section>
</Layout>
