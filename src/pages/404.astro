---
import Layout from '~/layouts/PageLayout.astro';
import { getHomePermalink } from '~/utils/permalinks';

const metadata = { title: 'Seite nicht gefunden' };
---

<Layout metadata={metadata}>
  <section class="flex items-center justify-center min-h-[60vh] px-4">
    <div class="max-w-md text-center">
      <div class="text-8xl font-bold text-primary mb-6">404</div>
      <h1 class="text-2xl font-semibold text-page mb-3">Seite nicht gefunden</h1>
      <p class="text-muted leading-relaxed mb-8">
        Die gesuchte Seite existiert leider nicht. Vielleicht wurde sie verschoben oder der Link ist veraltet.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={getHomePermalink()} class="btn btn-primary">Zur Startseite</a>
        <a href="/contact" class="btn btn-secondary">Kontakt</a>
      </div>
    </div>
  </section>
</Layout>
