---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: 'Vorstand',
  description: 'Der Vorstand des TC Bühlertal – Kompetenz, Engagement und Vision.',
};

const board = [
  { role: 'Vorstand Sport', name: 'Jürgen Götz' },
  { role: 'Vorstand Betrieb', name: 'Robin Ganter' },
  { role: 'Vorstand Öffentlichkeit', name: 'Johannes Braun' },
  { role: 'Sportwart', name: 'Fabrice Huck' },
  { role: 'Kassier', name: 'Johannes Pfeiffer, Simon Kellermeier' },
  { role: 'Schriftführer', name: 'Rico Früh' },
  { role: 'Jugendwart', name: null },
  { role: 'Bauwart', name: 'Rainer Ganter, Robin Ganter' },
  { role: 'Festwart', name: 'Rico Früh' },
  { role: 'Pressewart', name: 'Jürgen Götz' },
  { role: 'Beisitzer', name: 'Wolfgang Kohler, Rainer Ganter, Uwe Seifermann' },
];
---

<Layout metadata={metadata}>
  <Hero
    image={{
      src: '~/assets/images/racket-in-clay.png',
      alt: 'Vorstand TC Bühlertal',
    }}
  >
    <Fragment slot="title">Unser Vorstand</Fragment>
    <Fragment slot="subtitle">Kompetenz, Engagement und Vision für den TC Bühlertal.</Fragment>
  </Hero>

  <section class="max-w-3xl mx-auto px-4 py-10 space-y-8">
    <div class="rounded-2xl border border-gray-500/20 bg-light p-6">
      <p class="text-muted leading-relaxed">
        Unser Vorstand setzt sich aus engagierten und kompetenten Mitgliedern zusammen, die mit viel Einsatz und
        Leidenschaft daran arbeiten, den Verein erfolgreich zu führen und weiterzuentwickeln.
      </p>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-page mb-4">Vorstandsteam im Überblick</h2>

      <div class="rounded-2xl border border-gray-500/20 overflow-hidden">
        {
          board.map((member, i) => (
            <div
              class:list={[
                'flex items-start justify-between gap-4 px-5 py-4 text-sm',
                i % 2 === 0 ? 'bg-light' : 'bg-dark',
                i > 0 ? 'border-t border-gray-500/20' : '',
              ]}
            >
              <span class="text-muted w-44 shrink-0">{member.role}</span>
              <span class:list={['font-medium text-right', member.name ? 'text-page' : 'text-muted italic']}>
                {member.name ?? 'unbesetzt'}
              </span>
            </div>
          ))
        }
      </div>
    </div>

    <div class="rounded-2xl border border-gray-500/20 bg-light p-6 space-y-4">
      <h2 class="text-xl font-semibold text-page">Gemeinsam für den Verein</h2>
      <p class="text-muted leading-relaxed">
        Unser Vorstand arbeitet eng zusammen, um den Verein bestmöglich zu führen und weiterzuentwickeln. Dabei stehen
        die Interessen unserer Mitglieder stets im Vordergrund. Wir setzen uns dafür ein, dass unser Tennisverein nicht
        nur sportlich erfolgreich ist, sondern auch eine starke Gemeinschaft bildet, in der sich jeder wohlfühlen kann.
      </p>
    </div>

    <div class="rounded-2xl border border-gray-500/20 bg-light p-6 space-y-3">
      <h2 class="text-xl font-semibold text-page">Kontakt</h2>
      <p class="text-muted leading-relaxed">
        Haben Sie Fragen oder Anregungen? Der Vorstand steht Ihnen gerne zur Verfügung.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 pt-1">
        <a class="btn btn-primary" href="mailto:tcbuehlertal@web.de">tcbuehlertal@web.de</a>
        <a class="btn btn-secondary" href="/contact">Kontaktformular</a>
      </div>
      <p class="text-muted text-sm">Persönliche Gespräche sind nach Terminvereinbarung jederzeit möglich.</p>
    </div>

    <p class="text-muted text-sm">
      Wir freuen uns auf Ihre Anregungen und darauf, den Verein gemeinsam mit Ihnen weiter voranzubringen!<br />
      <span class="font-medium text-page">Sportliche Grüße, der Vorstand des TC Bühlertal</span>
    </p>
  </section>
</Layout>
